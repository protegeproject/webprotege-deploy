# =============================================================================
# WebProtege Docker Compose Environment
# =============================================================================
#
# Copy this file to .env before running docker compose:
#
#   cp .env.example .env
#
# The defaults below are suitable for local development.  Self-hosted
# deployments should change SERVER_HOST to the public hostname.

# ---------------------------------------------------------------------------
# Public hostname for the WebProtege + Keycloak stack.
#
# This value is used by Nginx, Keycloak, and the backend services to
# construct URLs for redirects, CORS, and OAuth flows.
#
# For local development the default works out of the box if you add
# an entry to your hosts file:
#
#   127.0.0.1  webprotege-local.edu
#
# Self-hosted deployments should set this to the public hostname,
# e.g. webprotege.example.org
# ---------------------------------------------------------------------------
SERVER_HOST=webprotege-local.edu

# ---------------------------------------------------------------------------
# MongoDB connection URI.
# The default points at the bundled mongo service in docker-compose.yml.
# ---------------------------------------------------------------------------
MONGO_URL=mongodb://mongo:27017/webprotege

# ---------------------------------------------------------------------------
# Keycloak client secret for the 'user-management' client.
# Used by webprotege-user-management-service to authenticate against
# Keycloak for admin operations (e.g. user creation, password resets).
# Leave empty initially — see the Keycloak documentation for how to
# retrieve or set this value.
# ---------------------------------------------------------------------------
ADMIN_CLI_SECRET=

# ---------------------------------------------------------------------------
# Keycloak superuser credentials.
#
# These are the bootstrap admin credentials for the Keycloak admin console
# itself (at http://<SERVER_HOST>/keycloak/admin/).  They are used by:
#
#   - Operators signing in to the Keycloak admin UI
#   - The entrypoint script for post-import realm patching
#   - The docker-compose healthcheck for keycloak
#
# The defaults below are suitable for local development ONLY.  Any deployment
# reachable beyond your local machine should set strong credentials here
# before first boot.  Rotating the password later requires resetting the
# Keycloak H2 volume (see 'Stopping and Resetting' in the README).
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password
